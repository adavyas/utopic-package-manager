{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": false,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "python/utopic/node",
    "rootDir": "node"
  },
  "include": ["node/**/*.ts"]
}
